# UmoyaPool backend configuration
PORT=3000
NODE_ENV=development

# Bearer key accepted for API access in development
API_KEY=umoyapool-dev-key

# Required by admin-only routes via the x-admin-key header
ADMIN_KEY=umoyapool-admin-key

# Secret for wallet session JWTs — change in any real deployment
JWT_SECRET=umoyapool-dev-jwt-secret-change-me
JWT_TTL_SECONDS=43200

STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
